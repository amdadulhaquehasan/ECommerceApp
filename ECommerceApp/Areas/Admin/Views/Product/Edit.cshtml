@model ECommerceApp.PresentationLayer.Modules.Products.ViewModel.ProductEditViewModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="category-page">
    <h1>Edit Product</h1>
    <p class="lead">Update product details.</p>

    <div class="category-form-card">
        <form asp-area="Admin" asp-controller="Product" asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="UpdatedDate" />
            <input type="hidden" asp-for="ImagePath" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SKU" class="form-label"></label>
                <input asp-for="SKU" class="form-control" />
                <span asp-validation-for="SKU" class="text-danger"></span>
            </div>
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <div class="mb-2">
                    <img src="@Model.ImagePath" alt="@Model.Name" style="max-height: 120px;" class="rounded" />
                    <p class="small text-muted">Current image. Upload a new file to replace.</p>
                </div>
            }

            <input type="file" name="imageFile" class="form-control" accept=".jpg, .jpeg, .png" />

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-category-primary">Save</button>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-category-outline">Cancel</a>
                <a asp-area="Admin" asp-controller="Product" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-category-outline">Details</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}