@model ECommerceApp.PresentationLayer.Modules.Categories.ViewModel.CategoryCreateViewModel
@{
    ViewData["Title"] = "Create Category";
}

<div class="category-page">
    <h1>Create Category</h1>
    <p class="lead">Add a new product category.</p>

    <div class="category-form-card">
        <form asp-area="Admin" asp-controller="Category" asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Electronics" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" placeholder="Short description" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-category-primary">Create</button>
                <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-category-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}