@model List<ECommerceApp.PresentationLayer.Modules.Orders.ViewModel.OrderConfirmViewModel>

@{
    ViewData["Title"] = "My Orders";
}

<h2 class="mb-4">My Orders</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No orders found.
    </div>
}
else
{
    <table class="table table-bordered table-striped">

        <thead>
            <tr>
                <th>Order Id</th>
                <th>Order Date</th>
                <th>Total</th>
                <th>Status</th>
                <th width="120"></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var order in Model)
            {
                <tr>

                    <td>@order.OrderId</td>

                    <td>
                        @order.OrderDate.ToString("dd MMM yyyy")
                    </td>

                    <td>
                        ৳ @order.TotalAmount
                    </td>

                    <td>
                        @order.Status
                    </td>

                    <td>
                        <a asp-action="Details"
                               asp-route-id="@order.OrderId"
                               class="btn btn-primary btn-sm">
                            Details
                        </a>
                    </td>

                </tr>
            }

        </tbody>

    </table>
}