@model ECommerceApp.PresentationLayer.Modules.Products.ViewModel.ProductEditViewModel

@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-4">

    <div class="row">

        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath"
                     alt="@Model.Name"
                     class="img-fluid rounded" />
            }
        </div>

        <div class="col-md-8">

            <h1>@Model.Name</h1>

            <p class="text-muted">@Model.Description</p>

            <p><strong>Price:</strong> @Model.Price.ToString("C")</p>

            <p><strong>SKU:</strong> @Model.SKU</p>

            <p><strong>Category:</strong> @(Model.CategoryName ?? "—")</p>

            <div class="mt-3">
                <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="productName" value="@Model.Name" />
                    <input type="hidden" name="unitPrice" value="@Model.Price" />
                    <label for="qty">Quantity</label>
                    <input type="number" id="qty" name="quantity" value="1" min="1" class="form-control d-inline-block" style="width: 80px;" />
                    <button type="submit" class="btn btn-primary">Add to cart</button>
                </form>

                <a asp-controller="Store"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                    Back to list
                </a>
            </div>

        </div>

    </div>

</div>