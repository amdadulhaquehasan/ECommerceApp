@model IReadOnlyList<ECommerceApp.PresentationLayer.Modules.Products.ViewModel.ProductListViewModel>
@{
    ViewData["Title"] = "Products";
}

<div class="category-page">
    <h1>Products</h1>
    <p class="lead">Manage your products.</p>

    <p>
        <a asp-action="Create" class="btn btn-category-primary">New Product</a>
    </p>

    <div class="category-card">
        <div class="card-body p-0">
            @if (Model.Count == 0)
            {
                <div class="p-4 text-center text-muted">No products yet. Create one to get started.</div>
            }
            else
            {
                <ul class="category-list">
                    @foreach (var item in Model)
                    {
                        <li class="category-list-item">
                            <div>
                                <span class="category-name">@item.Name</span>
                                <div class="category-meta">@item.SKU · @item.CategoryName · @item.Price.ToString("C")</div>
                            </div>
                            <div class="category-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-category-outline btn-sm">Details</a>
                                <a asp-action="Edit" asp-route-productId="@item.Id" class="btn btn-category-outline btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-category-danger btn-sm">Delete</a>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>