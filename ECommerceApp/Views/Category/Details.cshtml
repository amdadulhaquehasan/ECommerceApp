@model ECommerceApp.PresentationLayer.Modules.Categories.ViewModel.CategoryEditViewModel
@{
    ViewData["Title"] = "Category Details";
}

<div class="category-page">
    <h1>@Model.Name</h1>
    <p class="lead">Category details</p>

    <div class="category-card">
        <div class="card-body">
            <div class="detail-row">
                <div class="detail-label">Name</div>
                <div class="detail-value">@Model.Name</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Description</div>
                <div class="detail-value">@(Model.Description ?? "—")</div>
            </div>
            <div class="detail-row">
                <div class="detail-label">Created</div>
                <div class="detail-value">@Model.CreatedDate.ToShortDateString()</div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-category-primary">Edit</a>
        <a asp-action="Index" class="btn btn-category-outline">Back to List</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-category-danger">Delete</a>
    </div>
</div>